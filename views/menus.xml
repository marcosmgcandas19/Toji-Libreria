<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_toji_books" model="ir.actions.act_window">
            <field name="name">Libros Toji</field>
            <field name="res_model">product.template</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crea tu primer libro
                </p>
            </field>
        </record>

        <menuitem id="menu_toji_root"
                  name="Toji Store"
                  sequence="10"/>

        <menuitem id="menu_toji_books"
                  name="Libros"
                  parent="menu_toji_root"
                  action="action_toji_books"
                  sequence="10"/>
    </data>
</odoo>