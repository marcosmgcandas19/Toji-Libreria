<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="product_template_form_view_inherit_toji" model="ir.ui.view">
            <field name="name">product.template.form.inherit.toji</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                
                <xpath expr="//div[hasclass('oe_title')]" position="after">
                    <group>
                        <group string="Configuración Toji">
                            <field name="website_published" widget="boolean"/>
                            <field name="image_url" widget="url" placeholder="https://ejemplo.com/imagen.jpg"/>
                        </group>
                    </group>
                </xpath>

                <xpath expr="//notebook" position="inside">
                    <page name="library" string="Librería">
                        <group>
                            <group string="Información de Autor">
                                <field name="author_ids" widget="many2many_tags"/>
                            </group>
                            <group string="Descripción Literaria">
                                <field name="synopsis" nolabel="1" placeholder="Escriba la sinopsis del libro..."/>
                            </group>
                        </group>
                    </page>
                </xpath>

            </field>
        </record>

        <record id="product_template_tree_view_inherit_toji" model="ir.ui.view">
            <field name="name">product.template.tree.inherit.toji</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_tree_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="website_published" string="Publicado"/>
                    <field name="image_url" optional="hide"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>